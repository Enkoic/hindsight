# LLM for summarization — set one of the two
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional OpenAI-compatible base URL (Volcengine Ark, DeepSeek, local llama.cpp, etc.)
# Example: https://ark.cn-beijing.volces.com/api/coding/v3
OPENAI_BASE_URL=

# Which provider to use: anthropic | openai
HINDSIGHT_LLM_PROVIDER=anthropic
HINDSIGHT_LLM_MODEL=claude-sonnet-4-6

# ActivityWatch HTTP server
AW_SERVER_URL=http://localhost:5600

# Claude Code logs root (leave blank for default ~/.claude/projects)
CLAUDE_PROJECTS_DIR=

# Codex CLI sessions root (leave blank for default ~/.codex/sessions)
CODEX_SESSIONS_DIR=

# Cursor IDE chat history (leave blank for default
# ~/Library/Application Support/Cursor/User/workspaceStorage on macOS)
CURSOR_STORAGE_DIR=

# OpenAI/ChatGPT data export — point at the unzipped folder or directly at conversations.json
CHATGPT_EXPORT_PATH=

# Notion export (optional)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Obsidian vault root (optional; enables `hindsight export obsidian`)
OBSIDIAN_VAULT_DIR=

# Local SQLite store path.
# Default (leave blank): macOS → ~/Library/Application Support/hindsight/hindsight.sqlite
#                         Linux → $XDG_DATA_HOME/hindsight/hindsight.sqlite (or ~/.local/share/hindsight/)
# The data dir and DB file are chmod'd 0700 / 0600 so raw transcripts stay user-only.
HINDSIGHT_DB=
